# Server-only secrets. Do not prefix these with VITE_ or they will be exposed to the browser.
VIVO_APP_ID=your_vivo_app_id_here
VIVO_APP_KEY=your_vivo_app_key_here
VIVO_CHAT_MODEL=Doubao-Seed-2.0-mini

# OpenAI-compatible VLM provider for click-region image understanding.
VLM_BASE_URL=https://llmapi.paratera.com
VLM_API_KEY=your_vlm_api_key_here
VLM_MODEL=Qwen3-VL-30B-A3B-Thinking

# OpenAI-compatible image provider.
IMAGE_BASE_URL=https://llmapi.paratera.com
IMAGE_API_KEY=your_image_api_key_here
IMAGE_MODEL=Doubao-Seedream-4.5

PORT=3001
